FDRE_STORAGE_BACKEND=local
FDRE_MODEL_PUBLIC_BASE_URL=http://127.0.0.1:8010
FDRE_MODEL_SECRET_KEY=change-me
FDRE_ADMIN_EMAILS=admin@example.com
FDRE_MODEL_CUSTOMER_ID=local-customer
FDRE_MODEL_WORKSPACE_ID=default

# Auth0 hosted login
FDRE_AUTH0_DOMAIN=example.auth0.com
FDRE_AUTH0_CLIENT_ID=replace-me
FDRE_AUTH0_CLIENT_SECRET=replace-me
FDRE_AUTH0_MGMT_CLIENT_ID=replace-me
FDRE_AUTH0_MGMT_CLIENT_SECRET=replace-me
FDRE_AUTH0_CONNECTION_NAME=Username-Password-Authentication

# Hosted persistence
FDRE_HOSTED_BUCKET=replace-me
FDRE_HOSTED_DYNAMODB_TABLE=replace-me
FDRE_HOSTED_DYNAMODB_KEY_MODE=pk_sk
FDRE_HOSTED_PREFIX=fdre-market
AWS_REGION=ap-south-1
AWS_DEFAULT_REGION=ap-south-1
FDRE_WORKSPACE_ROOT=/var/app/fdre-workspace
